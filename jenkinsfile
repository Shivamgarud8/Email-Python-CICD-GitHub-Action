pipeline {
    agent any

    environment {
        EC2_USER = "ubuntu"
        EC2_IP = "52.53.223.137"
        APP_DIR = "/home/ubuntu/Email-App"
        CREDENTIAL_ID = "ubuntu"
        PORT = "5000"
    }

    stages {

        stage('Checkout Repository') {
            steps {
                echo "📥 Cloning repository..."
                checkout scm
            }
        }

        stage('Deploy to EC2') {
            steps {
                echo "🚀 Deploying application..."

                sshagent(credentials: ["${CREDENTIAL_ID}"]) {

                    sh """
                    echo "📂 Creating project directory..."
                    ssh -o StrictHostKeyChecking=no ${EC2_USER}@${EC2_IP} "mkdir -p ${APP_DIR}"

                    echo "📦 Uploading project files..."
                    scp -o StrictHostKeyChecking=no -r app.py requirements.txt templates Dockerfile README.MD ${EC2_USER}@${EC2_IP}:${APP_DIR}/

                    echo "⚙️ Installing dependencies and starting app..."
                    ssh -o StrictHostKeyChecking=no ${EC2_USER}@${EC2_IP} "
                        cd ${APP_DIR}

                        sudo apt update -y
                        sudo apt install -y python3-pip python3-venv

                        rm -rf venv
                        python3 -m venv venv
                        . venv/bin/activate

                        pip install --upgrade pip
                        pip install -r requirements.txt
                        pip install gunicorn

                        pkill gunicorn || true

                        nohup gunicorn -w 4 -b 0.0.0.0:${PORT} app:app > app.log 2>&1 &
                    "
                    """
                }
            }
        }

        stage('Health Check') {
            steps {
                echo "🩺 Checking application..."

                script {
                    def result = sh(
                        script: "curl -s -o /dev/null -w '%{http_code}' http://${EC2_IP}:${PORT}/",
                        returnStdout: true
                    ).trim()

                    if (result != "200") {
                        error("❌ Application is not reachable")
                    } else {
                        echo "✅ Application is running successfully!"
                    }
                }
            }
        }
    }

    post {
        success {
            echo "🎉 Deployment successful!"
            echo "🌐 Visit: http://${EC2_IP}:${PORT}"
        }

        failure {
            echo "❌ Deployment failed! Check logs."
        }
    }
}
